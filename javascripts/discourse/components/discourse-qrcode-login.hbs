{{#if this.shouldRender}}
  <div class="qrcode-login-connector">
    <div class="qrcode-or-divider">
      <span>扫码登录</span>
    </div>
  </div>
  <div
    class="qrcode-login-section"
    data-active-type={{this.selectedQrcodeType}}
    {{did-insert this.setup}}
    {{will-destroy this.teardown}}
  >
    {{!-- Tab 标签切换（下划线指示器风格） --}}
    <div class="qrcode-tabs">
      <button
        class="qrcode-tab {{if (eq this.selectedQrcodeType 'wecom') 'active'}}"
        data-type="wecom"
        {{on "click" (fn this.selectQrcodeType "wecom")}}
        title="企业微信扫码登录"
        type="button"
      >
        <span class="qrcode-tab-badge qrcode-tab-badge--wecom">企</span>
        企业微信
      </button>
      <button
        class="qrcode-tab {{if (eq this.selectedQrcodeType 'classin') 'active'}}"
        data-type="classin"
        {{on "click" (fn this.selectQrcodeType "classin")}}
        title="ClassIn App 扫码登录"
        type="button"
      >
        <span class="qrcode-tab-badge qrcode-tab-badge--classin">C</span>
        ClassIn
      </button>
    </div>

    {{!-- 主体内容区：加载 / 错误 / 二维码 --}}
    <div class="qrcode-body">
      {{#if this.isLoadingQrcode}}
        <div class="qrcode-loading">
          <div class="qrcode-spinner"></div>
          <span>加载中...</span>
        </div>
      {{else if this.qrcodeError}}
        <div class="qrcode-error-box">
          <div class="qrcode-error-icon">
            {{!-- 刷新图标 --}}
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M20 12a8 8 0 0 1-13.6 5.7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <path d="M4 12a8 8 0 0 1 13.6-5.7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <polyline points="17.5 6.5 17.5 2.5 21.5 6.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              <polyline points="6.5 17.5 6.5 21.5 2.5 17.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="qrcode-error-text">{{this.qrcodeError}}</p>
          <button {{on "click" this.retryLoadQrcode}} class="qrcode-retry-btn" type="button">
            刷新二维码
          </button>
        </div>
      {{else}}
        {{#if (eq this.selectedQrcodeType 'wecom')}}
          <div class="qrcode-box-wrapper">
            <div id="qrcode-wecom" class="qrcode-box"></div>
            <div class="qrcode-status-text">{{this.wecomStatusText}}</div>
            <div class="qrcode-instruction">
              {{!-- 手机扫码图标 --}}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="5" y="2" width="14" height="20" rx="3" stroke="currentColor" stroke-width="1.8"/>
                <circle cx="12" cy="17.5" r="1" fill="currentColor"/>
              </svg>
              <span>打开企业微信 App 扫码</span>
            </div>
          </div>
        {{else if (eq this.selectedQrcodeType 'classin')}}
          {{#if this.classinAvailable}}
            <div class="qrcode-box-wrapper">
              <div id="qrcode-classin" class="qrcode-box"></div>
              <div class="qrcode-status-text {{if (eq this.classinStatusText '请使用 ClassIn App 扫描二维码') '' 'qrcode-status-text--active'}}">{{this.classinStatusText}}</div>
              <div class="qrcode-instruction">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="5" y="2" width="14" height="20" rx="3" stroke="currentColor" stroke-width="1.8"/>
                  <circle cx="12" cy="17.5" r="1" fill="currentColor"/>
                </svg>
                <span>打开 ClassIn App 扫码</span>
              </div>
            </div>
          {{else}}
            <div class="qrcode-placeholder">
              <div class="qrcode-placeholder-title">功能即将上线</div>
              <div class="qrcode-placeholder-desc">ClassIn 扫码登录功能开发中</div>
            </div>
          {{/if}}
        {{/if}}
      {{/if}}
    </div>
  </div>
{{/if}}
